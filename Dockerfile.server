FROM golang:1.24-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /out/tsundere-server ./cmd/tsundere-server

FROM alpine:3.21
RUN apk add --no-cache ca-certificates tzdata
COPY --from=build /out/tsundere-server /usr/local/bin/tsundere-server
VOLUME /data
ENV TSUNDERE_DB=/data/tsundere.db
EXPOSE 8420
ENTRYPOINT ["tsundere-server"]
