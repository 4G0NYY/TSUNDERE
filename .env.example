# Public URL of the server — must match the GitHub OAuth callback host.
TSUNDERE_BASE_URL=https://status.example.com

# GitHub OAuth app (callback URL: <TSUNDERE_BASE_URL>/auth/callback)
TSUNDERE_GITHUB_CLIENT_ID=
TSUNDERE_GITHUB_CLIENT_SECRET=

# Comma-separated GitHub usernames allowed into the admin UI.
TSUNDERE_ADMIN_USERS=4G0NYY

# Token for the local agent (create the agent in the admin UI first).
TSUNDERE_AGENT_TOKEN=
