FROM golang:1.24-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /out/tsundere-agent ./cmd/tsundere-agent

FROM alpine:3.21
# ca-certificates for HTTPS checks; iputils gives a proper ping binary
RUN apk add --no-cache ca-certificates tzdata iputils
COPY --from=build /out/tsundere-agent /usr/local/bin/tsundere-agent
ENTRYPOINT ["tsundere-agent"]
